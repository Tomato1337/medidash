// Medical Documents Management System - Prisma Schema
// PostgreSQL with pgvector extension for semantic search

generator client {
    provider        = "prisma-client"
    engineType      = "client"
    output          = "./generated/prisma"
    previewFeatures = ["postgresqlExtensions"]
}

datasource db {
    provider   = "postgresql"
    extensions = [vector]
}

// ============================================================================
// ENUMS
// ============================================================================

enum Role {
    USER
    ADMIN
}

enum DocumentStatus {
    UPLOADING // Файл загружается в MinIO
    PARSING
    PROCESSING // Документ обрабатывается (парсинг, анонимизация, векторизация)
    COMPLETED // Обработка завершена успешно
    FAILED // Ошибка при обработке
}

enum PiiType {
    NAME // ФИО
    ADDRESS // Адрес
    PHONE // Телефон
    EMAIL // Email
    DATE // Дата рождения
    ID // Медицинский ID, СНИЛС, паспорт
    OTHER // Другие персональные данные
}

// ============================================================================
// USER MANAGEMENT
// ============================================================================

model User {
    id        String   @id @default(cuid())
    email     String   @unique
    name      String
    password  String
    role      Role     @default(USER)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    refreshTokens RefreshToken[]
    records       Record[]

    @@index([email])
}

model RefreshToken {
    id        String   @id @default(cuid())
    token     String   @unique
    userId    String
    expiresAt DateTime
    createdAt DateTime @default(now())

    // Relations
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@index([token])
}

// ============================================================================
// DOCUMENT MANAGEMENT
// ============================================================================

// Record - группа связанных медицинских документов (например, все документы одного визита к врачу)
model Record {
    id                     String         @id @default(cuid())
    userId                 String
    title                  String // Автоматически генерируется AI или задаётся пользователем
    description            String? // Опциональное описание
    date                   DateTime       @default(now()) // Дата создания записи или извлечённая дата
    summary                String? // Суммаризация всех документов в Record
    status                 DocumentStatus @default(UPLOADING)
    expectedDocumentsCount Int? // Ожидаемое количество документов (для проверки готовности)
    createdAt              DateTime       @default(now())
    updatedAt              DateTime       @updatedAt
    deletedAt              DateTime?

    // Relations
    user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
    documents Document[]
    tags      RecordTag[]

    @@index([userId])
    @@index([date])
}

// Document - отдельный медицинский документ (PDF или текстовый файл)
model Document {
    id               String         @id @default(cuid())
    recordId         String
    userId           String // Денормализация для быстрого доступа
    title            String // Автоматически генерируется AI
    description      String? // Опциональное описание
    fileName         String // Уникальное имя файла в MinIO
    originalFileName String // Имя файла при загрузке
    mimeType         String // application/pdf, text/plain
    fileSize         Int // Размер в байтах
    minioUrl         String // URL файла в MinIO
    minioBucket      String         @default("medical-documents")
    minioObjectKey   String // Ключ объекта в MinIO
    status           DocumentStatus @default(UPLOADING)
    errorMessage     String? // Сообщение об ошибке, если status = FAILED
    failedPhase      String? // Фаза, на которой произошла ошибка: "parsing" | "processing"
    extractedText    String?        @db.Text // Извлечённый текст из PDF (до анонимизации)
    metadata         Json? // Метаданные документа (pageCount, etc.)
    processedAt      DateTime? // Когда завершена обработка
    createdAt        DateTime       @default(now())
    updatedAt        DateTime       @updatedAt
    deletedAt        DateTime?

    // Relations
    record         Record          @relation(fields: [recordId], references: [id], onDelete: Cascade)
    chunks         DocumentChunk[] // Разбитый на части текст с embeddings
    piiMappings    PiiMapping[] // Маппинг анонимизированных данных
    processingLogs ProcessingLog[] // Логи обработки

    @@index([recordId])
    @@index([userId])
    @@index([status])
    @@index([createdAt])
}

// DocumentChunk - часть документа с векторным представлением для семантического поиска
model DocumentChunk {
    id         String                       @id @default(cuid())
    documentId String
    userId     String // Денормализация для быстрого доступа
    content    String                       @db.Text // Анонимизированный текст чанка
    order      Int // Порядковый номер чанка в документе
    embedding  Unsupported("vector(1536)")? // Векторное представление (OpenAI embeddings)
    createdAt  DateTime                     @default(now())
    updatedAt  DateTime                     @updatedAt

    // Relations
    document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

    @@index([documentId])
    @@index([userId])
    @@index([order])
}

// PiiMapping - маппинг персональных данных для возможности деанонимизации
model PiiMapping {
    id           String   @id @default(cuid())
    documentId   String
    userId       String // Денормализация
    original     String // Оригинальное значение (зашифровано)
    replacement  String // Замена (например, "[PATIENT_NAME_1]")
    type         PiiType
    encryptionIv String? // Initialization Vector для AES шифрования
    createdAt    DateTime @default(now())

    // Relations
    document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

    @@index([documentId])
    @@index([userId])
}

// ProcessingLog - логи обработки документов для отладки
model ProcessingLog {
    id         String   @id @default(cuid())
    documentId String
    step       String // "parsing", "anonymization", "vectorization", "tagging"
    status     String // "started", "completed", "failed"
    message    String?  @db.Text
    metadata   Json? // Дополнительные данные
    createdAt  DateTime @default(now())

    // Relations
    document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

    @@index([documentId])
    @@index([createdAt])
}

// ============================================================================
// TAGS & CATEGORIZATION
// ============================================================================

// Tag - теги для категоризации документов
model Tag {
    id          String   @id @default(cuid())
    name        String   @unique
    description String?
    color       String? // HEX цвет для UI
    isSystem    Boolean  @default(false) // Системные теги (автоматические) vs пользовательские
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    // Relations
    records RecordTag[]
}

// RecordTag - связь многие-ко-многим между Record и Tag
model RecordTag {
    id        String   @id @default(cuid())
    recordId  String
    tagId     String
    createdAt DateTime @default(now())

    // Relations
    record Record @relation(fields: [recordId], references: [id], onDelete: Cascade)
    tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

    @@unique([recordId, tagId])
    @@index([recordId])
    @@index([tagId])
}

// ============================================================================
// SYSTEM SETTINGS
// ============================================================================

// SystemSetting - настройки системы
model SystemSetting {
    id        String   @id @default(cuid())
    key       String   @unique
    value     String   @db.Text
    category  String // "ai", "storage", "processing"
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([category])
}
