# Application
NODE_ENV=dev
API_GATEWAY_PORT=3000
LOG_LEVEL=debug

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/medical_docs?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-16-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production-min-16-chars
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# Microservices URLs
DOCUMENT_SERVICE_URL=http://localhost:3001
PROCESSING_SERVICE_URL=http://localhost:3002
AI_SERVICE_URL=http://localhost:3003
SEARCH_SERVICE_URL=http://localhost:3004

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
