# Database Configuration
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/medical_docs?schema=public"
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=medical_docs

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password

# MinIO Configuration
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=your-minio-root-password-change-in-production
MINIO_ACCESS_KEY=your-minio-access-key-change-in-production
MINIO_SECRET_KEY=your-minio-secret-key-change-in-production
MINIO_BUCKET_NAME=medical-documents
MINIO_USE_SSL=false

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# API Gateway
API_GATEWAY_PORT=3000

# Document Service
DOCUMENT_SERVICE_PORT=3001
DOCUMENT_SERVICE_HOST=localhost

# Processing Service
PROCESSING_SERVICE_PORT=3002
PROCESSING_SERVICE_HOST=localhost

# AI Service
AI_SERVICE_PORT=3003
AI_SERVICE_HOST=localhost
OPENAI_API_KEY=your-openai-api-key

# Search Service
SEARCH_SERVICE_PORT=3004
SEARCH_SERVICE_HOST=localhost

# BullMQ Configuration
BULL_QUEUE_NAME=document-processing
BULL_QUEUE_PREFIX=medical-docs

# Application Configuration
NODE_ENV=dev # dev | prod
LOG_LEVEL=debug
CORS_ORIGIN=http://localhost:5173

# PgVector Configuration
VECTOR_DIMENSIONS=1536
