FROM node:20-slim

RUN apt-get update && apt-get install -y procps openssl rsync curl && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY services/ai-service/package.json services/ai-service/package-lock.json ./

RUN npm ci

COPY prisma/schema.prisma /app/prisma/schema.prisma
COPY prisma/package.json prisma/package-lock.json /app/prisma/

RUN cd /app/prisma && npm ci

COPY services/shared-types /app/shared-types

RUN cd /app/shared-types && npm ci && npm run build

COPY services/ai-service .

EXPOSE 3003

CMD sh -c "cd /app/prisma && npm run migrate:deploy && sleep 5 && mkdir -p /app/dist/prisma/generated && rsync -av --exclude='*.dll.node' /app/prisma/generated/ /app/dist/prisma/generated/ && cd /app && npm run start:dev"