NODE_ENV=dev #  dev | prod
BACKEND_PORT=3000

DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_NAME=health_helper

# JWT Configuration (ВАЖНО: Замените на свои секретные ключи!)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long-please-change-me
JWT_EXPIRES_IN=1d

# JWT Access Token (для аутентификации)
JWT_ACCESS_TOKEN_SECRET=your-access-token-secret-min-32-chars-change-me
JWT_ACCESS_TOKEN_EXPIRATION_MS=900000

# JWT Refresh Token (для обновления токенов)
JWT_REFRESH_TOKEN_SECRET=your-refresh-token-secret-min-32-chars-change-me
JWT_REFRESH_TOKEN_EXPIRATION_MS=604800000
